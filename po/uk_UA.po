#: pisi/cli/addrepo.py:15
msgid ""
"Add a repository\n"
"\n"
"Usage: add-repo <repo> <indexuri>\n"
"\n"
"<repo>: name of repository to add\n"
"<indexuri>: URI of index file\n"
"\n"
"NB: We support only local files (e.g., /a/b/c) and http:// URIs at the moment\n"
msgstr ""
"Додати репозиторій\n"
"\n"
"Використовування: add-repo <repo> <indexuri>\n"
"\n"
"<repo> - Ім'я репозиторія, який ви хочете додати,\n"
"<indexuri> - URI індексного файлу.\n"
"\n"
"Примітка: Ми підтримуємо тільки локальні файли (напр. a/b/c) та http:// URI на даний момент.\n"

#: pisi/cli/addrepo.py:33
msgid "add-repo options"
msgstr "опції add-repo (додавання репозиторія)"

#: pisi/cli/addrepo.py:38
msgid "Ignore repository distribution check"
msgstr "Ігнорувати перевірку поширення репозиторій"

#: pisi/cli/addrepo.py:45
msgid "Does not fetch repository index and does not check distribution match"
msgstr "Не збирає індекс репозиторія та не перевіряє відповідність розподілу"

#: pisi/cli/addrepo.py:53
msgid "Add repository at given position (0 is first)"
msgstr "Додати репозиторій на даній позиції (0 це перша)"

