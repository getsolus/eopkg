msgstr "Αναζήτηση στο όνομα του πακέτου"

#: pisi/cli/search.py:68
msgid "Search in the package summary"
msgstr "Αναζήτηση στην περίληψη του πακέτου"

#: pisi/cli/search.py:74
msgid "Search in the package description"
msgstr "Αναζήτηση στην περιγραφή του πακέτου"

