msgstr "Ανακατασκευή βάσεων δεδομένων eopkg;"

#: pisi/cli/remove.py:16
msgid ""
"Remove eopkg packages\n"
"\n"
"Usage: remove <package1> <package2> ... <packagen>\n"
"\n"
"Remove package(s) from your system. Just give the package names to remove.\n"
"\n"
"You can also specify components instead of package names, which will be\n"
"expanded to package names.\n"
msgstr ""
"Κατάργηση πακέτων eopkg\n"
"\n"
"Χρήση: remove <package1> <package2> ... <packagen>\n"
"\n"
"Κατάργηση πακέτου(ων) από το σύστημά σας. Απλά δώστε τα ονόματα των πακέτων που θέλετε να καταργήσετε.\n"
"\n"
"Μπορείτε επίσης να καθορίσετε στοιχεία αντί για ονόματα πακέτων, τα οποία θα\n"
"επεκταθούν σε ονόματα πακέτων.\n"

#: pisi/cli/remove.py:34
msgid "remove options"
msgstr "αφαίρεση επιλογών"

#: pisi/cli/remove.py:47
msgid "Remove component's and recursive components' packages"
msgstr "Κατάργηση πακέτων στοιχείων και αναδρομικών στοιχείων"

#: pisi/cli/removeorphans.py:16
msgid ""
"Remove orphaned packages\n"
"\n"
"Usage: remove-orphans\n"
"\n"
"Remove any unused orphan packages from the system that were automatically\n"
"installed as a dependency of another package.\n"
"\n"
"Only packages that have no reverse dependencies outside of the automatically\n"
"installed list will be removed.\n"
msgstr ""
"Κατάργηση ορφανών πακέτων\n"
"\n"
"Χρήση: remove-orphans\n"
"\n"
"Κατάργηση όλων των αχρησιμοποίητων ορφανών πακέτων από το σύστημα που εγκαταστάθηκαν αυτόματα\n"
"ως εξάρτηση άλλου πακέτου.\n"
"\n"
"Θα καταργηθούν μόνο τα πακέτα που δεν έχουν αντίστροφες εξαρτήσεις εκτός της αυτόματα\n"
"εγκατεστημένης λίστας.\n"

#: pisi/cli/removeorphans.py:34
msgid "remove-orphans options"
msgstr "επιλογές κατάργησης ορφανών"

#: pisi/cli/removerepo.py:12
msgid ""
"Remove repositories\n"
"\n"
"Usage: remove-repo <repo1> <repo2> ... <repon>\n"
"\n"
"Remove all repository information from the system.\n"
msgstr ""
"Κατάργηση αποθετηρίων\n"
"\n"
"Χρήση: remove-repo <repo1> <repo2> ... <repon>\n"
"\n"
"Κατάργηση όλων των πληροφοριών αποθετηρίου από το σύστημα.\n"

#: pisi/cli/repopriority.py:19
msgid ""
"Set a repository's priority\n"
"\n"
"Usage: repo-priority <repo> <priority>\n"
"\n"
"<repo>: Name of repository to adjust priority\n"
"<priority>: Set the repository's priority at given position (0 is first)\n"
msgstr ""
"Ορισμός προτεραιότητας αποθετηρίου\n"
"\n"
"\n"
"Χρήση: repo-priority  <repo> <priority>\n"
"\n"
"<repo>: Όνομα αποθετηρίου για το οποίο θα ρυθμιστεί η προτεραιότητα\n"
"<priority>: Ορισμός της προτεραιότητας του αποθετηρίου στη δεδομένη θέση (το 0 είναι το πρώτο)\n"

#: pisi/cli/repopriority.py:44
msgid "Priority needs to be a number"
msgstr "Η προτεραιότητα πρέπει να είναι ένας αριθμός"

