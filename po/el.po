#: pisi/cli/rebuilddb.py:15
msgid ""
"Rebuild Databases\n"
"\n"
"Usage: rebuilddb [ <package1> <package2> ... <packagen> ]\n"
"\n"
"Rebuilds the eopkg databases\n"
"\n"
"If package specs are given, they should be the names of package\n"
"dirs under /var/lib/eopkg\n"
msgstr ""
"Ανακατασκευή βάσεων δεδομένων\n"
"\n"
"Χρήση: rebuilddb [ <package1> <package2> ... <packagen> ]\n"
"\n"
"Ανακατασκευάζει τις βάσεις δεδομένων eopkg.\n"
"\n"
"Εάν δοθούν προδιαγραφές πακέτων, αυτές πρέπει να είναι τα ονόματα των καταλόγων πακέτων\n"
"στο /var/lib/eopkg.\n"

#: pisi/cli/rebuilddb.py:32
msgid "rebuild-db options"
msgstr "επιλογές rebuild-db"

#: pisi/cli/rebuilddb.py:39
