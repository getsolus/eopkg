#: pisi/cli/addrepo.py:15
msgid ""
"Add a repository\n"
"\n"
"Usage: add-repo <repo> <indexuri>\n"
"\n"
"<repo>: name of repository to add\n"
"<indexuri>: URI of index file\n"
"\n"
"NB: We support only local files (e.g., /a/b/c) and http:// URIs at the moment\n"
msgstr ""
"Adiciona um repositório\n"
"\n"
"Uso: add-repo <repo> <indexuri>\n"
"\n"
"<repo>: nome do repositório para adicionar\n"
"<indexuri>: URI do arquivo index\n"
"\n"
"Obs.: Suportamos apenas arquivos locais (ex.: /a/b/c) e http:// no momento\n"

#: pisi/cli/addrepo.py:33
msgid "add-repo options"
msgstr "opções do add-repo"

