#: pisi/cli/removerepo.py:12
msgid ""
"Remove repositories\n"
"\n"
"Usage: remove-repo <repo1> <repo2> ... <repon>\n"
"\n"
"Remove all repository information from the system.\n"
msgstr ""
"Remove repositórios\n"
"\n"
"Uso: remove-repo <repo1> <repo2> ... <repon>\n"
"\n"
"Remove do sistema todas as informações do repositório.\n"

#: pisi/cli/repopriority.py:19
msgid ""
"Set a repository's priority\n"
"\n"
"Usage: repo-priority <repo> <priority>\n"
"\n"
"<repo>: Name of repository to adjust priority\n"
"<priority>: Set the repository's priority at given position (0 is first)\n"
msgstr ""
"Definir a prioridade de um repositório\n"
"\n"
"Utilização: repo-priority <repo> <priority> \n"
"\n"
"<repo>: Nome do repositório para ajustar a prioridade\n"
"<priority>: Definir a prioridade do repositório numa determinada posição (0 é o primeiro)\n"

#: pisi/cli/repopriority.py:44
msgid "Priority needs to be a number"
msgstr "A prioridade tem de ser um número"

