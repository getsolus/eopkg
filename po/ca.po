msgstr "Ignora els conflictes de fitxers"

#: pisi/cli/upgrade.py:67 pisi/cli/install.py:61
msgid "Ignore package conflicts"
msgstr "Ignora els conflictes de paquets"

#: pisi/cli/upgrade.py:74
msgid "Upgrade component's and recursive components' packages"
msgstr "Actualitza els paquets dels components i dels components recursius"

#: pisi/cli/upgrade.py:82
msgid "Name of the to be upgraded packages' repository"
msgstr "Nom del repositori dels paquets per actualitzar"

#: pisi/cli/upgrade.py:89 pisi/cli/install.py:91
msgid "Fetch upgrades but do not install."
msgstr "Obtén les actualitzacions però no les instal·lis."

#: pisi/cli/upgrade.py:97
msgid ""
"When upgrading system, ignore packages and components whose basenames match "
