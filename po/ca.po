msgstr "Cerca al nom del paquet"

#: pisi/cli/search.py:68
msgid "Search in the package summary"
msgstr "Cerca al resum del paquet"

#: pisi/cli/search.py:74
msgid "Search in the package description"
msgstr "Cerca a la descripció del paquet"

#: pisi/cli/searchfile.py:15
msgid ""
"Search for a file\n"
"\n"
"Usage: search-file <path1> <path2> ... <pathn>\n"
"\n"
"Finds the installed package which contains the specified file.\n"
msgstr ""
"Cerca d'un fitxer\n"
"\n"
"Ús: search-file <path1> <path2> ... <pathn>\n"
"\n"
"Troba el paquet instal·lat que conté el fitxer especificat.\n"

#: pisi/cli/searchfile.py:29
